# Add your actual Supabase credentials here
# VITE_API_BASE_URL=http://localhost:8080
# Preferred for SSE container routing (explicitly points to api-sse).
# If omitted, frontend falls back to a VITE_API_BASE_URL-derived URL, then http://localhost:8081.
# Dev example:  VITE_API_SSE_URL=http://localhost:8081
# Prod example: VITE_API_SSE_URL=https://sse.your-domain.com
# VITE_API_SSE_URL=
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=
# Cloudflare Turnstile site key (safe for frontend)
# VITE_TURNSTILE_SITE_KEY=
# VITE_TURNSTILE_SITE_KEY_DEV=
# VITE_TURNSTILE_SITE_KEY_PROD=
# VITE_AUTHDBG=true
# Signal page only: enable multiplex SSE stream (/api/stream/signals)
# Phase-3 observation mode: keep opt-in only.
# Default is false when unset.
# VITE_ENABLE_SIGNAL_MUX_SSE=false
# Optional mux SSE telemetry (uses VITE_AUTHDBG when unset).
# VITE_SSE_OBS=false
# VITE_SSE_OBS_SAMPLE_EVERY=100

# Note: Copy one of the .env.development or .env.production files to .env 
# and add your actual credentials
# Important: Turnstile secret key must NOT be placed in frontend env files.
# Configure it in Supabase Dashboard -> Authentication -> Bot and Abuse Protection.
