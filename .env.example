# Production-first frontend environment template.
# Copy this file to .env and replace placeholders with real production values.
VITE_API_BASE_URL=https://api.your-domain.com
VITE_API_SSE_URL=https://sse.your-domain.com
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_public_key
# Cloudflare Turnstile site key (safe for frontend)
VITE_TURNSTILE_SITE_KEY=your-cloudflare-turnstile-site-key
VITE_AUTHDBG=false
# Signal page only: enable multiplex SSE stream (/api/stream/signals)
# Phase-3 observation mode: keep opt-in only.
# Default is false when unset.
VITE_ENABLE_SIGNAL_MUX_SSE=false
# Optional mux SSE telemetry (uses VITE_AUTHDBG when unset).
VITE_SSE_OBS=false
VITE_SSE_OBS_SAMPLE_EVERY=100

# Note: Keep .env pointed at production endpoints only.
# Important: Turnstile secret key must NOT be placed in frontend env files.
# Configure it in Supabase Dashboard -> Authentication -> Bot and Abuse Protection.
