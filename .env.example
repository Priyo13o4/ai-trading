# Add your actual Supabase credentials here
# VITE_API_BASE_URL=http://localhost:8080
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=
# Cloudflare Turnstile site key (safe for frontend)
# VITE_TURNSTILE_SITE_KEY=
# VITE_TURNSTILE_SITE_KEY_DEV=
# VITE_TURNSTILE_SITE_KEY_PROD=

# Note: Copy one of the .env.development or .env.production files to .env 
# and add your actual credentials
# Important: Turnstile secret key must NOT be placed in frontend env files.
# Configure it in Supabase Dashboard -> Authentication -> Bot and Abuse Protection.
